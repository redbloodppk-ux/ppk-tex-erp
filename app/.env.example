# ─────────────────────────────────────────────────────────────────────
# PPK TEX ERP — Environment variables
# Copy this file to `.env.local` and fill in the real values.
# Never commit .env.local to git.
# ─────────────────────────────────────────────────────────────────────

# Supabase project URL — from Supabase dashboard → Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT-ID.supabase.co

# Supabase anon (public) key — safe to expose to browser
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# Supabase service role key — SERVER ONLY. Never expose to client.
# Used by Edge Functions / Server Actions for admin operations.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# Supabase project ID (the part before .supabase.co) — for type generation
SUPABASE_PROJECT_ID=YOUR-PROJECT-ID

# Optional: site URL (used for email confirmation redirects)
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Optional: app default time zone (display only; storage is always UTC)
NEXT_PUBLIC_DEFAULT_TZ=Asia/Kolkata
